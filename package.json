{
    "name":        "@stagetimerio/grandiose",
    "version":     "0.0.4",
    "description": "Node.js N-API native addon wrapping the NDI SDK.",
    "homepage":    "https://github.com/stagetimerio/grandiose#readme",
    "keywords":    [ "NDI", "video", "streaming", "napi", "native" ],
    "author":      "Streampunk Media et al",
    "license":     "Apache-2.0",
    "main":        "index.js",
    "types":       "index.d.ts",
    "gypfile":     true,
    "repository":  { "type": "git", "url": "git+https://github.com/stagetimerio/grandiose.git" },
    "bugs":        { "url": "https://github.com/stagetimerio/grandiose/issues" },
    "publishConfig": { "registry": "https://npm.pkg.github.com" },
    "dependencies": {
        "bindings":         "1.5.0",
        "got":              "14.6.6",
        "mkdirp":           "3.0.1",
        "tmp":              "0.2.5",
        "execa":            "9.6.1",
        "cross-zip":        "4.0.1",
        "shelljs":          "0.10.0"
    },
    "devDependencies": {
        "shx":              "0.4.0",
        "vitest":           "^4.1.0"
    },
    "scripts": {
        "install":          "node ndi.js && node-gyp rebuild",
        "build":            "node-gyp rebuild",
        "test":             "vitest run",
        "clean":            "shx rm -rf ndi build"
    }
}
